      const logoFallback = document.getElementById("logo-fallback");
      if (logoImg && logoFallback) {
        logoImg.addEventListener("error", () => {
          logoImg.classList.add("hidden");
          logoFallback.classList.remove("hidden");
        });
      }

      // Pill: show fallback when image fails
      const pillImg = document.getElementById("pill-img");
      const pillFallback = document.getElementById("pill-fallback");
      if (pillImg && pillFallback) {
        pillImg.addEventListener("load", () =>
          pillFallback.classList.add("hidden"),
        );
        pillImg.addEventListener("error", () => {
          pillImg.classList.add("hidden");
          pillFallback.classList.remove("hidden");
        });
      }
